
  {
    "compilerOptions": {
      "target": "ES2021",
      "module": "CommonJS",
      "moduleResolution": "node",
      "declaration": true,
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "allowSyntheticDefaultImports": true,
      "skipLibCheck": true,
      "strict": true,
      "noImplicitAny": false,
      "forceConsistentCasingInFileNames": true,
      "outDir": "dist",
      "baseUrl": "./",
      "paths": {
        "@app/*": ["src/*"],
        "@shared/*": ["../../packages/shared/*"]
      }
    }
  }
